{
  "name": "snapback",
  "version": "0.1.0",
  "description": "Snapback - a cross-platform file time machine with scoped rules and automatic retention.",
  "homepage": "https://github.com/snapback-app/snapback",
  "main": "out/main/index.js",
  "author": {
    "name": "Snapback",
    "email": "dev.walidbaharwal@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "electron-store": "^10.0.0",
    "hash-wasm": "^4.11.0",
    "ignore": "^6.0.2",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "monaco-editor": "^0.52.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
